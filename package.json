{
  "name": "renewcred-headless-cms",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "admin-frontend",
    "public-frontend"
  ],
  "scripts": {
    "dev:backend": "npm --workspace backend run dev",
    "dev:admin": "npm --workspace admin-frontend run dev",
